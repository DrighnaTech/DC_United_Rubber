           AVG(COALESCE(NULLIF("Invoice_Amount_", '')::NUMERIC, 0))                     AS avg_invoice_value,
           MIN("Invoice_Date_(Date)"::DATE)                 AS first_date,
           MAX("Invoice_Date_(Date)"::DATE)                 AS last_date,
           COUNT(DISTINCT "Customer_Name_")           AS unique_customers
         FROM deduped
         WHERE "Status_" = $1 AND "Invoice_Date_(Date)"::DATE >= $2::DATE AND "Invoice_Date_(Date)"::DATE <= $3::DATE 
